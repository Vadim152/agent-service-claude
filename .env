AGENT_SERVICE_APP_NAME=agent-service
AGENT_SERVICE_API_PREFIX=/api/v1
AGENT_SERVICE_HOST=0.0.0.0
AGENT_SERVICE_PORT=8000
AGENT_SERVICE_STEPS_INDEX_DIR=.agent/steps_index
AGENT_SERVICE_LLM_MODEL=GigaChat-Max

# Настройки GigaChat
GIGACHAT_CLIENT_ID=019abf9e-3a65-73f7-befe-cafefcce2a57
GIGACHAT_CLIENT_SECRET=e2b76013-9ce2-40bc-b66d-ce2f0bf1316d
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_VERIFY_SSL=false

# Управление телеметрией Chroma
CHROMA_TELEMETRY_IMPL=chromadb.telemetry.impl.noop.NoopTelemetry

# Corporate proxy mode (mTLS)
AGENT_SERVICE_CORP_MODE=false
AGENT_SERVICE_CORP_PROXY_HOST=
AGENT_SERVICE_CORP_PROXY_PATH=/sbe-ai-pdlc-integration-code-generator/v1/chat/proxy/completions
AGENT_SERVICE_CORP_MODEL=GigaChat-2-Max
AGENT_SERVICE_CORP_CERT_FILE=
AGENT_SERVICE_CORP_KEY_FILE=
AGENT_SERVICE_CORP_CA_BUNDLE_FILE=
AGENT_SERVICE_CORP_REQUEST_TIMEOUT_S=30
AGENT_SERVICE_JIRA_VERIFY_SSL=false
AGENT_SERVICE_OPENCODE_BACKEND_MODE=http
AGENT_SERVICE_OPENCODE_ADAPTER_URL=http://127.0.0.1:8011

OPENCODE_ADAPTER_HOST=127.0.0.1
OPENCODE_ADAPTER_PORT=8011
OPENCODE_ADAPTER_BINARY=opencode.cmd
OPENCODE_ADAPTER_SERVER_HOST=127.0.0.1
OPENCODE_ADAPTER_SERVER_PORT=4096
OPENCODE_ADAPTER_DEFAULT_AGENT=build
OPENCODE_ADAPTER_MODEL_MODE=config
# OPENCODE_ADAPTER_MODEL_OVERRIDE=gigachat/GigaChat-Max
# OPENCODE_ADAPTER_CONFIG_FILE=C:\path\to\opencode.json
# OPENCODE_ADAPTER_CONFIG_DIR=C:\path\to\.opencode
OPENCODE_ADAPTER_AGENT_MAP_JSON={"agent":"build","default":"build"}
OPENCODE_ADAPTER_INHERIT_PARENT_ENV=true
OPENCODE_ADAPTER_PRINT_LOGS=false
